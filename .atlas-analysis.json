  "keyFeatures": [
    "Multi-ZIP portfolio analysis with Git repository discovery",
    "Automated skill extraction from code, dependencies, and commit history",
    "Repository intelligence including language detection, framework analysis, and health scoring",
    "Evidence-based project insights with ranking and timeline visualization",
    "Resume and portfolio generation with customizable representation preferences",
    "Multiple client interfaces: CLI, Textual TUI, and experimental React client",
    "Privacy-conscious consent management with optional LLM integration (OpenAI/Ollama)",
    "Project timeline and skills chronology tracking"
  ],
